{
  "manifest_version": 3,
  "name": "Sovereign Browser (Dev Prototype)",
  "version": "0.0.1",
  "description": "Unykorn agentic browser side panel — OpenClaw gateway + research corpus. NOT the shipped product.",
  "permissions": ["sidePanel", "storage", "activeTab"],
  "host_permissions": [
    "http://127.0.0.1:18789/*",
    "http://localhost:18789/*"
  ],
  "action": {
    "default_title": "Open DONK Sidecar"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}

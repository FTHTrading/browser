{
  "name": "@unykorn/agent-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Sovereign Browser → OpenClaw bridge. Hydrates the Digital Giant sovereign agent contract and binds the 7-function map onto the OpenClaw gateway. No AGPL cores.",
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./digital-giant": {
      "types": "./dist/digital_giant.d.ts",
      "import": "./dist/digital_giant.js"
    },
    "./model-router": {
      "types": "./dist/model_router.d.ts",
      "import": "./dist/model_router.js"
    },
    "./openclaw-tools": {
      "types": "./dist/openclaw_tools.d.ts",
      "import": "./dist/openclaw_tools.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
